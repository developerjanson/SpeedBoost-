# Partner Dashboard se milenge (Apps > Your App > Client credentials)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Aapki app jahan deploy hai us ka public HTTPS URL (Render/Railway/Fly.io wagera)
# Example: https://speedify-optimizer.onrender.com
HOST=https://your-app-url.com

# Comma separated scopes
SCOPES=read_products,write_products

# App ki price (USD/month) - billing.js isi ko use karta hai
APP_MONTHLY_PRICE=10.00

# true = trial ke bina live charge (testing ke liye Shopify dev store pe test_charge=true rakhein)
BILLING_TEST_MODE=true

PORT=3000
